{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    {
      "src": "/(?<path>.*)",
      "dest": "/api/index?p=$path",
      "continue": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "x-middleware-cache",
          "value": "no-cache"
        }
      ]
    }
  ]
}

